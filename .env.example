# Kalaikatha environment example
# Copy this file to .env.local (or .env) and fill in real values.
# Never commit real secrets to source control.

# --- Azure Vision ---
VITE_AZURE_VISION_ENDPOINT=https://your-cognitive-endpoint.cognitiveservices.azure.com/
VITE_AZURE_VISION_KEY=your_vision_key

# --- Azure OpenAI ---
VITE_AZURE_OPENAI_ENDPOINT=https://your-openai-endpoint.openai.azure.com/
VITE_AZURE_OPENAI_KEY=your_openai_key
VITE_AZURE_OPENAI_DEPLOYMENT=gpt-4

# --- Azure Translator ---
VITE_AZURE_TRANSLATOR_KEY=your_translator_key
VITE_AZURE_TRANSLATOR_REGION=centralindia
VITE_AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com/

# --- Azure Speech ---
VITE_AZURE_SPEECH_KEY=your_speech_key
VITE_AZURE_SPEECH_REGION=centralindia

# --- Azure Storage (Blob) ---
VITE_AZURE_STORAGE_ACCOUNT=your_storage_account
VITE_AZURE_STORAGE_KEY=your_storage_key
VITE_AZURE_STORAGE_CONTAINER=artisan-uploads

# --- Firebase (optional) ---
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXX

# --- Optional limits ---
VITE_MAX_AI_CALLS_PER_DAY=10

# Notes:
# - Vite exposes only variables prefixed with VITE_. Keep that prefix.
# - Use `.env.local` for local secrets and add it to `.gitignore` (already ignored).
